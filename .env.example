# API config
# Option 1 (recommended): keep relative base URL and use Vite proxy in development.
VITE_API_BASE_URL=/api/v1

# Option 2: split origin + path (used if VITE_API_BASE_URL is not set).
# VITE_API_ORIGIN=https://api.yourdomain.com
# VITE_API_BASE_PATH=/api/v1

# Dev-only proxy target for /api requests
VITE_DEV_API_PROXY_TARGET=http://65.108.14.4:8001
