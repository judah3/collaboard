# API config
# For production/static deployments, set API origin + path.
VITE_API_ORIGIN=https://api.yourdomain.com
VITE_API_BASE_PATH=/api/v1

# Optional fallback for local proxy-style setup:
# VITE_API_BASE_URL=/api/v1

# Dev-only proxy target for /api requests
VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:8000
